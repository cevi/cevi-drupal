{
    "extends": [
        "stylelint-config-standard",
        "stylelint-rscss/config"
    ],
    "rules": {
        "comment-whitespace-inside": null,
        "indentation": [4, {}],
        "unit-no-unknown": [true, { ignoreUnits: ["/lh/", "/svh/", "string"] }],
        "declaration-empty-line-before": null,
	  	"at-rule-no-unknown": null
    }
}