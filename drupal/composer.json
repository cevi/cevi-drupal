{
    "name": "cevi/drupal",
    "description": "Website for Cevi Groups",
    "version": "1.0.0",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Beat Temperli v/o Zottel <zottel@cevi.ch>"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require": {
        "composer/installers": "^2.0",
        "cweagans/composer-patches": "^1.6",
        "drupal/admin_toolbar": "^3",
        "drupal/core": "^11",
        "drupal/core-composer-scaffold": "^11",
        "drupal/environment_indicator": "^4",
        "drupal/field_group": "^4",
        "drupal/focal_point": "^2",
        "drupal/google_analytics": "^4",
        "drupal/honeypot": "^2",
        "drupal/leaflet": "^10",
        "drupal/metatag": "^2",
        "drupal/paragraphs": "^1.15",
        "drupal/pathauto": "^1.11",
        "drupal/recaptcha": "^3",
        "drupal/shield": "^1.7",
        "drupal/simple_sitemap": "^4",
        "drupal/twig_field_value": "^2",
        "drupal/type_style": "^1",
        "drupal/webform": "^6",
        "drush/drush": "^13"
    },
    "require-dev": {
        "drupal/coder": "^8.3",
        "phpunit/phpunit": "^9"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "drupal/core-composer-scaffold": true,
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "8.3.0",
            "ext-gd": "1",
            "ext-intl": "1",
            "ext-pdo_mysql": "1",
            "ext-zip": "1",
            "ext-apcu": "1"
        }
    },
    "autoload": {
        "classmap": [
            "scripts/composer/ScriptHandler.php"
        ]
    },
    "scripts": {
        "pre-install-cmd": [
            "DrupalProject\\composer\\ScriptHandler::checkComposerVersion"
        ],
        "pre-update-cmd": [
            "DrupalProject\\composer\\ScriptHandler::checkComposerVersion"
        ],
        "post-install-cmd": [
            "DrupalProject\\composer\\ScriptHandler::createRequiredFiles",
            "DrupalProject\\composer\\ScriptHandler::copyCeviFiles"
        ],
        "post-update-cmd": [
            "DrupalProject\\composer\\ScriptHandler::createRequiredFiles",
            "DrupalProject\\composer\\ScriptHandler::copyCeviFiles"
        ]
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            }
        },
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ]
        },
        "composer-exit-on-patch-failure": true,
        "patchLevel": {
            "drupal/core": "-p2"
        },
        "patches": []
    }
}
