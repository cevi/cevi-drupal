# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.

# --- Database ---
DRUPAL_DB_NAME=drupal
DRUPAL_DB_USER=drupal
DRUPAL_DB_PASS=change-me
DRUPAL_DB_ROOT_PASS=change-me-root

# --- Drupal ---
# Generate with: docker run --rm drupal php -r "echo \Drupal\Component\Utility\Crypt::randomBytesBase64(55);"
DRUPAL_HASH_SALT=change-me-generate-a-random-string

# Comma-separated regex patterns for trusted hosts
DRUPAL_TRUSTED_HOSTS=^localhost$,^127\.0\.0\.1$

# production | development
DRUPAL_ENV=development

# --- Caddy (production only) ---
# Apex domain only — Caddy auto-obtains certs for both apex and www.
# DNS: point both A records (example.com + www.example.com) at the VM IP.
CADDY_DOMAIN=example.com

# --- Xdebug (dev only, off by default) ---
# XDEBUG_MODE=debug
# XDEBUG_CLIENT_HOST=host.docker.internal

